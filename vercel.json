{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "loufypublish.vercel.app"
        }
      ],
      "destination": "https://loufypublisher.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/blogs",
      "destination": "/blogs"
    },
    {
      "source": "/blog/:slug",
      "destination": "/blog?slug=:slug"
    }
  ]
}
